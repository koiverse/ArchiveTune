{
  "oacpVersion": "0.3",
  "appId": "__APPLICATION_ID__",
  "displayName": "ArchiveTune",
  "appDomains": ["music", "audio", "streaming"],
  "appKeywords": ["music", "song", "track", "album", "artist", "playlist", "playback", "player", "streaming", "youtube music"],
  "appAliases": ["archivetune", "archive tune", "youtube music player", "music player"],
  "capabilities": [
    {
      "id": "play_music",
      "description": "Search and play music from YouTube Music, or resume the last playback session.",
      "domain": "music",
      "aliases": [
        "play music", "play song", "play track", "play album", "play artist",
        "resume music", "resume playback", "start music", "listen to music",
        "play on archivetune", "stream music"
      ],
      "examples": [
        "play music on ArchiveTune",
        "play Bohemian Rhapsody",
        "play songs by Taylor Swift",
        "play the album Abbey Road",
        "resume music",
        "listen to some jazz",
        "play lo-fi beats"
      ],
      "keywords": ["play", "music", "song", "track", "album", "artist", "listen", "resume", "start", "stream"],
      "disambiguationHints": [
        "Use this when the user wants to play music or a specific song/artist/album.",
        "This is a STREAMING player — it plays music from YouTube Music, not local files.",
        "If no query is given, resumes the last playback or opens the app.",
        "Do NOT use this for local-only music players like Auxio."
      ],
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "required": false,
          "description": "The song title or album name to play",
          "extractionHint": "Extract ONLY the song title or album name. Do NOT include the artist name here — put it in the artist parameter instead. For 'play Water by Tyla', query is 'Water'. For 'play some jazz', query is 'jazz'.",
          "examples": ["Bohemian Rhapsody", "Water", "Abbey Road", "lo-fi beats"],
          "prompt": "What would you like to listen to?"
        },
        {
          "name": "artist",
          "type": "string",
          "required": false,
          "description": "The artist or band name",
          "extractionHint": "Extract ONLY the artist or band name if mentioned. For 'play Water by Tyla', artist is 'Tyla'. For 'play songs by Taylor Swift', artist is 'Taylor Swift'. If no artist is mentioned, set to null.",
          "examples": ["Tyla", "Taylor Swift", "Queen", "Ed Sheeran"],
          "prompt": "By which artist?"
        }
      ],
      "confirmation": "never",
      "executionMessage": "Playing music on ArchiveTune.",
      "visibility": "public",
      "requiresForeground": true,
      "completionMode": "foreground_handoff",
      "sensitivity": "low",
      "sideEffects": "Starts audio playback which may be audible. Requires internet connection.",
      "idempotent": true,
      "invoke": {
        "android": {
          "type": "activity",
          "action": "__APPLICATION_ID__.oacp.ACTION_PLAY_MUSIC",
          "extrasMapping": {
            "query": "EXTRA_QUERY",
            "artist": "EXTRA_ARTIST"
          }
        }
      }
    },
    {
      "id": "pause_music",
      "description": "Pause the currently playing music in ArchiveTune.",
      "domain": "music",
      "aliases": ["pause music", "pause song", "pause playback", "stop music", "stop playing"],
      "examples": [
        "pause the music",
        "pause ArchiveTune",
        "stop playing music",
        "pause the song"
      ],
      "keywords": ["pause", "stop", "music", "song", "playback", "playing"],
      "disambiguationHints": [
        "Use this when the user wants to temporarily stop music playback.",
        "Prefer this over stop — pause keeps position.",
        "This controls ArchiveTune (YouTube Music streaming), not local music players."
      ],
      "parameters": [],
      "confirmation": "never",
      "executionMessage": "Pausing music.",
      "visibility": "public",
      "completionMode": "fire_and_forget",
      "sensitivity": "low",
      "idempotent": true,
      "invoke": {
        "android": {
          "type": "broadcast",
          "action": "__APPLICATION_ID__.oacp.ACTION_PAUSE_MUSIC"
        }
      }
    },
    {
